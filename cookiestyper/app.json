{
  "expo": {
    "name": "CookieTyper",
    "slug": "cookietyper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cookietyper",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zeus.cookietyper"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.zeus.cookietyper"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./withFloatingAssistant"
    ],
    "extra": {
      "eas": {
        "projectId": "a38a52f2-b606-4f73-b9a0-0729c3b3c6cc"
      }
    }
  }
}
